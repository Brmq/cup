    \{ id: 9, group: 'A', home: '\'c7\'e1\'e3\'df\'d3\'ed\'df', away: '\'df\'e6\'d1\'ed\'c7 \'c7\'e1\'cc\'e4\'e6\'c8\'ed\'c9', fh: '\uc0\u55356 \u56818 \u55356 \u56829 ', fa: '\u55356 \u56816 \u55356 \u56823 ' \},\
    \{ id: 10, group: 'H', home: '\'c3\'e6\'d1\'e6\'db\'e6\'c7\'ed', away: '\'c7\'e1\'c5\'df\'e6\'c7\'cf\'e6\'d1', fh: '\uc0\u55356 \u56826 \u55356 \u56830 ', fa: '\u55356 \u56810 \u55356 \u56808 ' \}\
  ];\
\
  /**\
   * State object holds the current player and room context.\
   */\
  const state = \{\
    playerName: null,\
    roomCode: null,\
    matchIndex: 0,\
    currentRoom: null\
  \};\
\
  /**\
   * Utility functions\
   */\
  function $(id) \{\
    return document.getElementById(id);\
  \}\
\
  function showScreen(name) \{\
    document.querySelectorAll('.screen').forEach((sec) => \{\
      sec.classList.remove('active');\
    \});\
    const target = document.getElementById(name);\
    if (target) target.classList.add('active');\
  \}\
\
  function generateCode() \{\
    return Math.floor(100000 + Math.random() * 900000).toString();\
  \}\
\
  function loadRooms() \{\
    try \{\
      return JSON.parse(localStorage.getItem('we26_rooms') || '\{\}');\
    \} catch (err) \{\
      console.warn('Error loading rooms', err);\
      return \{\};\
    \}\
  \}\
\
  function saveRooms(rooms) \{\
    localStorage.setItem('we26_rooms', JSON.stringify(rooms));\
  \}\
\
  /**\
   * Creates a new room and saves it to localStorage. The host becomes\
   * the first player and the room has empty predictions and no results\
   * yet. We set a lockAt timestamp 24 hours from now for demonstration.\
   */\
  function createRoom(playerName) \{\
    const rooms = loadRooms();\
    const code = generateCode();\
    const lockAt = Date.now() + 24 * 60 * 60 * 1000; // 24h from now\
    rooms[code] = \{\
      code,\
      createdAt: Date.now(),\
      lockAt,\
      players: [playerName],\
      predictions: \{\},\
      results: null\
    \};\
    saveRooms(rooms);\
    return code;\
  \}\
\
  /**\
   * Retrieves a room by code. Returns undefined if not found.\
   */\
  function getRoom(code) \{\
    const rooms = loadRooms();\
    return rooms[code];\
  \}\
\
  /**\
   * Updates a room record in localStorage.\
   */\
  function updateRoom(code, updater) \{\
    const rooms = loadRooms();\
    const room = rooms[code];\
    if (!room) return;\
    const updated = typeof updater === 'function' ? updater(\{ ...room \}) : updater;\
    rooms[code] = \{ ...room, ...updated \};\
    saveRooms(rooms);\
  \}\
\
  /**\
   * Adds a player to the room's players list if not already present.\
   */\
  function addPlayerToRoom(code, playerName) \{\
    updateRoom(code, (room) => \{\
      if (!room.players.includes(playerName)) \{\
        room.players.push(playerName);\
      \}\
      return room;\
    \});\
  \}\
\
  /**\
   * Save a player's predictions for a room. Predictions should be an array\
   * of objects with matchId, winner, homeScore, awayScore.\
   */\
  function savePredictions(code, playerName, predictions) \{\
    updateRoom(code, (room) => \{\
      room.predictions[playerName] = predictions;\
      return room;\
    \});\
  \}\
\
  /**\
   * Checks if all players in the room have submitted predictions (i.e.\
   * predictions count equals players count).\
   */\
  function allPlayersPredicted(room) \{\
    return room.players.every((p) => \{\
      return Array.isArray(room.predictions[p]) && room.predictions[p].length === MATCHES.length;\
    \});\
  \}\
\
  /**\
   * Generates actual match results randomly. Each match result has winner,\
   * homeScore and awayScore.\
   */\
  function generateActualResults() \{\
    return MATCHES.map(() => \{\
      let home = Math.floor(Math.random() * 5);\
      let away = Math.floor(Math.random() * 5);\
      let winner;\
      if (home > away) winner = 'home';\
      else if (away > home) winner = 'away';\
      else winner = 'draw';\
      return \{ winner, homeScore: home, awayScore: away \};\
    \});\
  \}\
\
  /**\
   * Calculate points for each player given predictions and actual results.\
   * Returns an object mapping playerName to points and correct count.\
   */\
  function calculateScores(room) \{\
    const results = room.results;\
    const scores = \{\};\
    room.players.forEach((p) => \{\
      scores[p] = \{ points: 0, correct: 0 \};\
      const preds = room.predictions[p] || [];\
      preds.forEach((pred, idx) => \{\
        const actual = results[idx];\
        if (!actual) return;\
        if (pred.winner === actual.winner) \{\
          scores[p].points += 10;\
          scores[p].correct++;\
          if (pred.homeScore === actual.homeScore && pred.awayScore === actual.awayScore) \{\
            scores[p].points += 20;\
          \}\
        \}\
      \});\
    \});\
    return scores;\
  \}\
\
  /**\
   * Event handlers and UI updates\
   */\
  function attachEventHandlers() \{\
    // Home actions\
    $('create-room').addEventListener('click', () => \{\
      const name = $('your-name').value.trim();\
      if (!name) \{\
        alert('\'d1\'cc\'c7\'c1\'f0 \'c7\'df\'ca\'c8 \'c7\'d3\'e3\'df');\
        return;\
      \}\
      state.playerName = name;\
      const code = createRoom(name);\
      state.roomCode = code;\
      state.currentRoom = getRoom(code);\
      showLobby();\
    \});\
\
    $('join-room-btn').addEventListener('click', () => \{\
      showScreen('join');\
    \});\
\
    $('join-back').addEventListener('click', () => \{\
      showScreen('home');\
    \});\
\
    $('join-room-submit').addEventListener('click', () => \{\
      const name = $('join-name').value.trim();\
      const code = $('join-code').value.trim();\
      if (!name || !code) \{\
        alert('\'d1\'cc\'c7\'c1\'f0 \'c7\'cf\'ce\'e1 \'c7\'d3\'e3\'df \'e6\'c7\'e1\'df\'e6\'cf');\
        return;\
      \}\
      const room = getRoom(code);\
      if (!room) \{\
        alert('\'c7\'e1\'df\'e6\'cf \'db\'ed\'d1 \'d5\'cd\'ed\'cd');\
