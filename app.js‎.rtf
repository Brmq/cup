    if (state.playerName === room.players[0]) \{\
      startBtn.style.display = 'inline-block';\
      if (room.results) \{\
        startBtn.textContent = '\'da\'d1\'d6 \'c7\'e1\'e4\'ca\'c7\'c6\'cc';\
      \} else if (allPlayersPredicted(room)) \{\
        startBtn.textContent = '\'c7\'cd\'ca\'d3\'c7\'c8 \'c7\'e1\'e4\'ca\'c7\'c6\'cc';\
