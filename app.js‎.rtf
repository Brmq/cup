      \}\
      state.playerName = name;\
      state.roomCode = code;\
      addPlayerToRoom(code, name);\
      state.currentRoom = getRoom(code);\
      showLobby();\
    \});\
\
    $('exit-room').addEventListener('click', () => \{\
      // Simply go back to home without deleting room\
      state.playerName = null;\
      state.roomCode = null;\
      state.currentRoom = null;\
      showScreen('home');\
    \});\
\
    $('start-predictions').addEventListener('click', () => \{\
      // Only host can start predictions and only when at least 1 other player joined\
      if (!state.currentRoom) return;\
      const room = state.currentRoom;\
      if (room.players.length < 2) \{\
        alert('\'ed\'cc\'c8 \'e6\'cc\'e6\'cf \'e1\'c7\'da\'c8\'ed\'e4 \'da\'e1\'ec \'c7\'e1\'c3\'de\'e1 \'e1\'c8\'cf\'c1 \'c7\'e1\'ca\'e6\'de\'da\'c7\'ca');\
        return;\
      \}\
      // If results already exist, skip predictions and show results\
      if (room.results) \{\
        showResults();\
      \} else \{\
        // Reset match index and start predictions\
        state.matchIndex = 0;\
        showPredictionPage();\
      \}\
    \});\
\
    $('save-prediction').addEventListener('click', () => \{\
      handleSavePrediction();\
    \});\
\
    $('skip-prediction').addEventListener('click', () => \{\
      // Treat skip as 0-0 draw prediction\
      $('winner-draw').checked = true;\
      $('score-home').value = 0;\
      $('score-away').value = 0;\
      handleSavePrediction();\
    \});\
\
    $('play-again').addEventListener('click', () => \{\
      // Clear predictions and results then go back to lobby\
      updateRoom(state.roomCode, (room) => \{\
      room.predictions = \{\};\
      room.results = null;\
      return room;\
      \});\
      state.currentRoom = getRoom(state.roomCode);\
      showLobby();\
    \});\
  \}\
\
  /**\
   * Populate and show the lobby screen.\
   */\
  function showLobby() \{\
    state.currentRoom = getRoom(state.roomCode);\
    const room = state.currentRoom;\
    if (!room) \{\
      alert('\'c7\'e1\'db\'d1\'dd\'c9 \'db\'ed\'d1 \'e3\'e6\'cc\'e6\'cf\'c9');\
      showScreen('home');\
      return;\
    \}\
    // Display room code\
    $('room-code-display').textContent = room.code;\
    // List players and their prediction status\
    const list = $('players-list');\
    list.innerHTML = '';\
    room.players.forEach((p) => \{\
      const li = document.createElement('li');\
      li.textContent = p;\
      const statusSpan = document.createElement('span');\
      statusSpan.classList.add('status');\
      if (room.predictions[p] && room.predictions[p].length === MATCHES.length) \{\
        statusSpan.textContent = '\uc0\u10004 \u65039 ';\
      \} else \{\
        statusSpan.textContent = '\uc0\u8987 ';\
      \}\
      li.appendChild(statusSpan);\
      list.appendChild(li);\
    \});\
    // Show message\
    const msg = $('lobby-message');\
    if (room.results) \{\
      msg.textContent = '\'ca\'e3 \'cd\'d3\'c7\'c8 \'c7\'e1\'e4\'ca\'c7\'c6\'cc\'a1 \'ed\'e3\'df\'e4\'df \'da\'d1\'d6\'e5\'c7.';\
    \} else if (allPlayersPredicted(room)) \{\
      msg.textContent = '\'cc\'e3\'ed\'da \'c7\'e1\'e1\'c7\'da\'c8\'ed\'e4 \'c3\'df\'e3\'e1\'e6\'c7 \'c7\'e1\'ca\'e6\'de\'da\'c7\'ca. \'ed\'e3\'df\'e4\'df \'c7\'cd\'ca\'d3\'c7\'c8 \'c7\'e1\'e4\'ca\'c7\'c6\'cc.';\
