    \{ id: 5, group: 'I', home: '\'dd\'d1\'e4\'d3\'c7', away: '\'c7\'e1\'d3\'e4\'db\'c7\'e1', fh: '\uc0\u55356 \u56811 \u55356 \u56823 ', fa: '\u55356 \u56824 \u55356 \u56819 ' \},\
