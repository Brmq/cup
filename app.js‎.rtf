    showScreen('lobby');\
  \}\
\
  /**\
   * Show prediction page for current match index.\
   */\
  function showPredictionPage() \{\
    const match = MATCHES[state.matchIndex];\
    $('match-counter').textContent = `$\{state.matchIndex + 1\} / $\{MATCHES.length\}`;\
    $('flag-home').textContent = match.fh;\
    $('name-home').textContent = match.home;\
    $('flag-away').textContent = match.fa;\
    $('name-away').textContent = match.away;\
    $('winner-home-name').textContent = match.home;\
    $('winner-away-name').textContent = match.away;\
    // Reset radio selection\
    document.querySelectorAll('input[name="winner"]').forEach((inp) => \{\
      inp.checked = false;\
    \});\
    // Reset scores\
    $('score-home').value = 0;\
    $('score-away').value = 0;\
    showScreen('predict');\
  \}\
\
  /**\
   * Save current prediction and move to next match or finish.\
   */\
  function handleSavePrediction() \{\
    const room = state.currentRoom;\
    if (!room) return;\
    // Determine winner\
    const winnerInput = document.querySelector('input[name="winner"]:checked');\
    const winner = winnerInput ? winnerInput.value : null;\
    const homeScore = parseInt($('score-home').value, 10);\
    const awayScore = parseInt($('score-away').value, 10);\
    if (!winner) \{\
      alert('\'c7\'ce\'ca\'d1 \'c7\'e1\'dd\'c7\'c6\'d2 \'c3\'e6 \'c7\'e1\'ca\'da\'c7\'cf\'e1');\
      return;\
    \}\
    // Build prediction record\
    const pred = \{\
      matchId: MATCHES[state.matchIndex].id,\
      winner,\
      homeScore,\
      awayScore\
    \};\
    // Append to existing predictions for this player\
    let preds = room.predictions[state.playerName] || [];\
    preds[state.matchIndex] = pred;\
    savePredictions(state.roomCode, state.playerName, preds);\
    state.currentRoom = getRoom(state.roomCode);\
    // Move to next match or finish\
    state.matchIndex++;\
    if (state.matchIndex < MATCHES.length) \{\
      showPredictionPage();\
    \} else \{\
      // finished predictions; go back to lobby\
      showLobby();\
    \}\
  \}\
\
  /**\
   * Generate results (only by host) and compute scores, then show them.\
   */\
  function computeResultsIfNeeded() \{\
    // Only host can compute results\
    const room = state.currentRoom;\
    if (!room || state.playerName !== room.players[0]) return;\
    if (room.results) return; // Already computed\
    // Generate actual results randomly\
    const actualResults = generateActualResults();\
    updateRoom(state.roomCode, (r) => \{\
      r.results = actualResults;\
      return r;\
    \});\
    state.currentRoom = getRoom(state.roomCode);\
  \}\
\
  /**\
   * Show final results with leaderboard and history.\
   */\
  function showResults() \{\
    const room = state.currentRoom;\
    if (!room) return;\
    // If host and results not yet computed but all predicted, compute now\
    if (!room.results && state.playerName === room.players[0] && allPlayersPredicted(room)) \{\
      computeResultsIfNeeded();\
    \}\
    // Compute scores\
    const scores = calculateScores(room);\
    const leaderboard = Object.entries(scores).sort((a, b) => b[1].points - a[1].points);\
    const listEl = $('leaderboard');\
    listEl.innerHTML = '';\
    leaderboard.forEach(([player, data], idx) => \{\
      const li = document.createElement('li');\
      li.textContent = `$\{idx + 1\}. $\{player\}`;\
      const span = document.createElement('span');\
      span.textContent = `$\{data.points\} \'e4\'de\'d8\'c9`;\
      li.appendChild(span);\
      listEl.appendChild(li);\
    \});\
    // Build history: for each match show prediction of each player and actual result\
    const histDiv = $('history');\
    histDiv.innerHTML = '';\
    MATCHES.forEach((match, idx) => \{\
      const actual = room.results ? room.results[idx] : null;\
      const title = document.createElement('h4');\
      title.textContent = `$\{match.home\} $\{actual ? actual.homeScore : '?'\} - $\{actual ? actual.awayScore : '?'\} $\{match.away\}`;\
      histDiv.appendChild(title);\
      room.players.forEach((p) => \{\
        const pred = (room.predictions[p] || [])[idx];\
        const div = document.createElement('div');\
        div.textContent = `$\{p\}: $\{pred ? pred.homeScore : '-'\}-$\{pred ? pred.awayScore : '-'\} ( $\{pred ? pred.winner === 'home' ? match.home : pred.winner === 'away' ? match.away : '\'ca\'da\'c7\'cf\'e1' : '\'97'\} )`;\
        histDiv.appendChild(div);\
      \});\
      const sep = document.createElement('hr');\
      histDiv.appendChild(sep);\
    \});\
    showScreen('results');\
  \}\
\
  // Run initialization after DOM ready\
  document.addEventListener('DOMContentLoaded', () => \{\
    attachEventHandlers();\
  \});\
\
\})();}